# Dev stack env — copy to .env.dev on the VPS and fill in real values.
# This file is committed; .env.dev is NOT.

# Postgres
POSTGRES_USER=dmtool_dev
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=dmtool_dev

# Backend
# Async URL used by the app at runtime (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://dmtool_dev:CHANGEME@dev-db:5432/dmtool_dev
# Sync URL used by Alembic migrations (psycopg2 driver). Keep credentials identical.
DATABASE_URL_SYNC=postgresql://dmtool_dev:CHANGEME@dev-db:5432/dmtool_dev
GROQ_API_KEY=
ENVIRONMENT=development
# SECRET_KEY is required (backend startup fails without it when DATABASE_URL
# uses a non-default password). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGEME

# Frontend
NEXT_PUBLIC_API_URL=https://dev.kochfe.de
